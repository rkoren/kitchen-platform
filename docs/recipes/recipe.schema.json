{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "ECRSpec": {
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "ecr",
          "title": "Type",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "scan_on_push": {
          "default": true,
          "title": "Scan On Push",
          "type": "boolean"
        },
        "image_tag_mutability": {
          "default": "MUTABLE",
          "enum": [
            "MUTABLE",
            "IMMUTABLE"
          ],
          "title": "Image Tag Mutability",
          "type": "string"
        },
        "lambda_access": {
          "default": false,
          "title": "Lambda Access",
          "type": "boolean"
        },
        "lifecycle_keep_last": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lifecycle Keep Last"
        }
      },
      "required": [
        "type",
        "name"
      ],
      "title": "ECRSpec",
      "type": "object"
    },
    "IAMRoleSpec": {
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "iam_role",
          "title": "Type",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "service": {
          "title": "Service",
          "type": "string"
        },
        "policies": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Policies",
          "type": "array"
        },
        "inline_policies": {
          "default": [],
          "items": {
            "$ref": "#/$defs/InlinePolicy"
          },
          "title": "Inline Policies",
          "type": "array"
        }
      },
      "required": [
        "type",
        "name",
        "service"
      ],
      "title": "IAMRoleSpec",
      "type": "object"
    },
    "InlinePolicy": {
      "additionalProperties": false,
      "description": "An inline allow policy for project-scoped access (e.g. a specific S3 bucket).",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "actions": {
          "items": {
            "type": "string"
          },
          "title": "Actions",
          "type": "array"
        },
        "resources": {
          "items": {
            "type": "string"
          },
          "title": "Resources",
          "type": "array"
        }
      },
      "required": [
        "name",
        "actions",
        "resources"
      ],
      "title": "InlinePolicy",
      "type": "object"
    },
    "LambdaSpec": {
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "lambda",
          "title": "Type",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "role": {
          "title": "Role",
          "type": "string"
        },
        "runtime": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Runtime"
        },
        "handler": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Handler"
        },
        "memory": {
          "default": 128,
          "title": "Memory",
          "type": "integer"
        },
        "timeout": {
          "default": 3,
          "title": "Timeout",
          "type": "integer"
        },
        "image_uri": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Image Uri"
        },
        "ecr_repo": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ecr Repo"
        },
        "environment": {
          "additionalProperties": {
            "type": "string"
          },
          "default": {},
          "title": "Environment",
          "type": "object"
        },
        "function_url": {
          "default": false,
          "title": "Function Url",
          "type": "boolean"
        },
        "function_url_auth": {
          "default": "AWS_IAM",
          "enum": [
            "AWS_IAM",
            "NONE"
          ],
          "title": "Function Url Auth",
          "type": "string"
        },
        "log_retention_days": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Log Retention Days"
        }
      },
      "required": [
        "type",
        "name",
        "role"
      ],
      "title": "LambdaSpec",
      "type": "object"
    },
    "RDSSpec": {
      "additionalProperties": false,
      "description": "A managed Postgres instance \u2014 e.g. the MLflow backend store that makes\nregistry champions persist across runs (see docs/decisions/mlflow-tracking-backend.md).\n\nThe master password is created and rotated by RDS in AWS Secrets Manager\n(``manage_master_user_password``) \u2014 it is never rendered into Terraform config\nor state. The generated ``<name>_master_user_secret_arn`` output is the ARN to\nwire into a project's ``secrets:`` manifest.",
      "properties": {
        "type": {
          "const": "rds",
          "title": "Type",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "engine_version": {
          "default": "16",
          "title": "Engine Version",
          "type": "string"
        },
        "instance_class": {
          "default": "db.t4g.micro",
          "title": "Instance Class",
          "type": "string"
        },
        "allocated_storage": {
          "default": 20,
          "title": "Allocated Storage",
          "type": "integer"
        },
        "backup_retention_days": {
          "default": 7,
          "title": "Backup Retention Days",
          "type": "integer"
        },
        "db_name": {
          "default": "mlflow",
          "title": "Db Name",
          "type": "string"
        },
        "username": {
          "default": "mlflow",
          "title": "Username",
          "type": "string"
        },
        "storage_encrypted": {
          "default": true,
          "title": "Storage Encrypted",
          "type": "boolean"
        },
        "multi_az": {
          "default": false,
          "title": "Multi Az",
          "type": "boolean"
        },
        "publicly_accessible": {
          "default": false,
          "title": "Publicly Accessible",
          "type": "boolean"
        },
        "deletion_protection": {
          "default": true,
          "title": "Deletion Protection",
          "type": "boolean"
        },
        "skip_final_snapshot": {
          "default": true,
          "title": "Skip Final Snapshot",
          "type": "boolean"
        },
        "db_subnet_group_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Db Subnet Group Name"
        },
        "vpc_security_group_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Vpc Security Group Ids",
          "type": "array"
        }
      },
      "required": [
        "type",
        "name"
      ],
      "title": "RDSSpec",
      "type": "object"
    },
    "S3Spec": {
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "s3",
          "title": "Type",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "versioning": {
          "default": false,
          "title": "Versioning",
          "type": "boolean"
        },
        "encryption": {
          "default": true,
          "title": "Encryption",
          "type": "boolean"
        },
        "public_access_block": {
          "default": true,
          "title": "Public Access Block",
          "type": "boolean"
        },
        "lifecycle_expiration_days": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lifecycle Expiration Days"
        }
      },
      "required": [
        "type",
        "name"
      ],
      "title": "S3Spec",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "name": {
      "title": "Name",
      "type": "string"
    },
    "region": {
      "default": "us-east-1",
      "title": "Region",
      "type": "string"
    },
    "resources": {
      "default": [],
      "items": {
        "discriminator": {
          "mapping": {
            "ecr": "#/$defs/ECRSpec",
            "iam_role": "#/$defs/IAMRoleSpec",
            "lambda": "#/$defs/LambdaSpec",
            "rds": "#/$defs/RDSSpec",
            "s3": "#/$defs/S3Spec"
          },
          "propertyName": "type"
        },
        "oneOf": [
          {
            "$ref": "#/$defs/S3Spec"
          },
          {
            "$ref": "#/$defs/IAMRoleSpec"
          },
          {
            "$ref": "#/$defs/ECRSpec"
          },
          {
            "$ref": "#/$defs/LambdaSpec"
          },
          {
            "$ref": "#/$defs/RDSSpec"
          }
        ]
      },
      "title": "Resources",
      "type": "array"
    }
  },
  "required": [
    "name"
  ],
  "title": "RecipeSpec",
  "type": "object"
}

resource "aws_lambda_function" "{{ name | tf_id }}" {
  function_name = "{{ name }}"
  role          = aws_iam_role.{{ role | tf_id }}.arn
{% if ecr_repo %}
  package_type = "Image"
  image_uri    = "${aws_ecr_repository.{{ ecr_repo | tf_id }}.repository_url}:latest"
{% elif image_uri %}
  package_type = "Image"
  image_uri    = "{{ image_uri }}"
{% else %}
  runtime = "{{ runtime }}"
  handler = "{{ handler }}"
{% endif %}
  memory_size = {{ memory }}
  timeout     = {{ timeout }}
{% if environment %}
  environment {
    variables = {
{%- for key, value in environment.items() %}
      {{ "%-*s"|format(env_key_width, key) }} = "{{ value }}"
{%- endfor %}
    }
  }
{% endif %}
{% if policy_count > 0 %}
  depends_on = [
{%- for i in range(1, policy_count + 1) %}
    aws_iam_role_policy_attachment.{{ role | tf_id }}_{{ i }},
{%- endfor %}
  ]
{% endif %}
}
{% if function_url %}
resource "aws_lambda_function_url" "{{ name | tf_id }}" {
  function_name      = aws_lambda_function.{{ name | tf_id }}.function_name
  authorization_type = "{{ function_url_auth }}"
}
{% if function_url_auth == "NONE" %}
resource "aws_lambda_permission" "{{ name | tf_id }}_url" {
  statement_id           = "FunctionURLAllowPublicAccess"
  action                 = "lambda:InvokeFunctionUrl"
  function_name          = aws_lambda_function.{{ name | tf_id }}.function_name
  principal              = "*"
  function_url_auth_type = "NONE"
}
{% endif %}
output "{{ name | tf_id }}_url" {
  value = aws_lambda_function_url.{{ name | tf_id }}.function_url
}
{% endif %}
